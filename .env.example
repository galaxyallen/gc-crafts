# Database (Vercel Postgres — Storage → Postgres → Connect to project)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Production site URL (sitemap, canonical links)
NEXT_PUBLIC_SITE_URL="https://www.galaxybz.com"

# NextAuth (required)
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
# Production:
NEXTAUTH_URL="https://www.galaxybz.com"
# Local dev:
# NEXTAUTH_URL="http://localhost:3000"

# Admin seed credentials (used by `npm run db:seed`)
ADMIN_EMAIL="admin@gccrafts.com"
ADMIN_PASSWORD="admin123456"

# Vercel Blob (auto-injected when Blob store is connected to the project)
# BLOB_READ_WRITE_TOKEN=""
# BLOB_STORE_ID=""          # OIDC auth (newer Vercel projects)
# BLOB_ACCESS="public"      # use "private" if the Blob store was created as Private

# Optional: inquiry email notifications
RESEND_API_KEY=""
NOTIFICATION_EMAIL="hello@gccrafts.com"
